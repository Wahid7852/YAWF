# Compiled object files
*.slo
*.lo
*.o
*.obj

# Precompiled headers
*.gch
*.pch

# Compiled dynamic libraries
*.so
*.dylib
*.dll

# Compiled static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app

# Temporary ui files
*.ui~
*.ui#

# Common build directory
build/

# app/build/icons is checked-in source assets for electron-builder, not a
# generated build directory, unlike the CMake build/ this pattern targets
!app/build/
!app/build/icons/
!app/build/icons/**

# IDE folders
.idea/
.vscode/
