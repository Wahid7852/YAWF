<component type="desktop-application">
  <id>${WIL_APP_ID}</id>
  <metadata_license>FSFAP</metadata_license>
  <project_license>GPL-3.0</project_license>
  <name>${WIL_FRIENDLY_NAME}</name>
  <summary>Unofficial WhatsApp desktop client</summary>
  <content_rating type="oars-1.1"/>

  <description>
    <p>
      YAWF (Yet Another WhatsApp Fork) is an unofficial WhatsApp desktop client
      for Linux written in C++ with gtkmm and WebKitGTK. It wraps WhatsApp Web in
      a native window and adds desktop integration plus power-user features.
    </p>
    <p>Features:</p>
    <ul>
      <li>System tray, notification sounds, autostart and multiple accounts</li>
      <li>Automatic recovery from WhatsApp Web crash screens</li>
      <li>Paste images from the clipboard straight into the composer</li>
      <li>Capture a screen region directly into a chat</li>
      <li>Telegram-style markdown formatting shortcuts</li>
      <li>Optional Ctrl+Enter to send</li>
    </ul>
    <p>YAWF is a maintained fork of WasIstLos by xeco23 (Enes Hecan).</p>
  </description>

  <launchable type="desktop-id">${WIL_APP_ID}.desktop</launchable>

  <screenshots>
    <screenshot type="default">
      <caption>The main window</caption>
      <image>https://raw.githubusercontent.com/Wahid7852/YAWF/master/screenshot/app.png</image>
    </screenshot>
  </screenshots>

  <url type="homepage">${WIL_HOMEPAGE}</url>
  <url type="bugtracker">${WIL_HOMEPAGE}/issues</url>
  <url type="vcs-browser">${WIL_HOMEPAGE}</url>

  <keywords>
    <keyword>chat</keyword>
    <keyword>messaging</keyword>
    <keyword>messenger</keyword>
    <keyword>whatsapp</keyword>
  </keywords>

  <developer id="io.github.wahid7852">
    <name>Wahid7852</name>
  </developer>
  <update_contact>wahidzk0091_AT_gmail.com</update_contact>

  <releases>
    <release version="2.0.0" date="${WIL_BUILD_DATE}">
      <description>
        <p>First release of the YAWF fork.</p>
        <ul>
          <li>Automatic recovery from WhatsApp Web crash screens</li>
          <li>Clipboard image paste and region screenshot into the composer</li>
          <li>Telegram-style markdown formatting shortcuts</li>
          <li>Optional Ctrl+Enter to send</li>
          <li>Faster startup and smoother UI</li>
        </ul>
      </description>
      <url>https://github.com/Wahid7852/YAWF/releases/tag/v${WIL_VERSION}</url>
    </release>
  </releases>
</component>
